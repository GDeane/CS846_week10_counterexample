 1 file changed, 26 insertions(+), 14 deletions(-)

diff --git a/Week10/B_1/calculate_grades.py b/Week10/B_1/calculate_grades.py
index 88ac2eb..da40d2e 100644
--- a/Week10/B_1/calculate_grades.py
